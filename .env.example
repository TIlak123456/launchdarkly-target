# =============================================================================
# LaunchDarkly SDK Keys — Part 2: Target
# =============================================================================
# Copy this file to .env and replace the placeholder values with your actual keys.
#
# You can find these in your LaunchDarkly dashboard:
#   1. Go to https://app.launchdarkly.com/settings/projects
#   2. Select your project
#   3. Find your environment (e.g., "Test")
#   4. Copy the SDK key (server-side) and Client-side ID
# =============================================================================

# Server-side SDK key (used by the Python/Flask backend)
LAUNCHDARKLY_SDK_KEY=sdk-your-server-side-sdk-key-here

# Client-side ID (used by the JavaScript SDK in the browser)
LAUNCHDARKLY_CLIENT_ID=your-client-side-id-here
